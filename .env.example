# Copy this file to .env and add your API keys
# You only need the key for the model you want to use

# For Claude (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# For OpenAI (GPT-5.1 / GPT-5.2 / GPT-5.3 Codex)
OPENAI_API_KEY=your_openai_api_key_here

# For ZhipuAI (GLM-5, OpenAI-compatible endpoint)
ZHIPU_API_KEY=your_zhipu_api_key_here

# For OpenRouter (default path for GLM-5 / MiniMax M2.5 / Kimi 2.5)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# For MiniMax direct API (optional, overrides OpenRouter for minimax_m2_5)
MINIMAX_API_KEY=your_minimax_api_key_here

# For Moonshot/Kimi direct API (optional, overrides OpenRouter for kimi_2_5)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# For Gemini (Google)
GOOGLE_API_KEY=your_google_api_key_here
